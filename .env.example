# =============================================================================
# FlexiCommerce — Variables para Docker Compose
# Copia este archivo a .env y completa los valores:  cp .env.example .env
# =============================================================================

# === Base de datos (PostgreSQL) ===
DB_USER=flexicommerce
DB_PASSWORD=dev_password
DB_NAME=flexicommerce_dev
# Puerto expuesto en el host (cámbialo si ya tienes Postgres en 5432)
DB_PORT=5432

# === Redis ===
REDIS_PORT=6379

# === Puertos expuestos en el host ===
FRONTEND_PORT=3000
BACKEND_PORT=3001
PGADMIN_PORT=5050

# === Backend ===
# OBLIGATORIO: genera uno con  openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRATION=7d
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
# Aplicar migraciones de Prisma al arrancar el contenedor (true/false)
RUN_MIGRATIONS=true

# === URLs públicas (se compilan dentro del bundle del frontend) ===
# Si cambias FRONTEND_PORT/BACKEND_PORT, actualiza estas URLs y reconstruye:
# docker compose build frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FlexiCommerce

# === Wompi Colombia (pagos) ===
# Obtener en: comercios.wompi.co → Desarrolladores
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=

# === Observabilidad (opcional) ===
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# === PgAdmin (perfil dev-tools) ===
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
